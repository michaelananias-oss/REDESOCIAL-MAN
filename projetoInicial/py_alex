@app.route("/calcularSalario", methods=['POST'])
def calcularSalario():
    codigo = request.form.get("codigo")
    horasExtras = float(request.form.get("horasExtras") or 0)
    adiantamento13 = request.form.get("adiantamento13")
    ferias = request.form.get("ferias")

    funcionario = buscarFuncionario(codigo)
    if funcionario is None:
        msg = "Funcionário não encontrado"
        return render_template("salario.html", mensagem=msg)

    salario = funcionario["salario"]

    salario_final = salario + horasExtras * 50

    if adiantamento13:
        salario_final += salario / 2

    if ferias:
        salario_final += salario / 3

    msg = f"Salário Simulado: R$ {salario_final:.2f}"
    return render_template("salario.html", mensagem=msg)


@app.route("/alterarSenha", methods=['POST'])
def alterarSenha():

    codigo = request.form.get("codigo")
    senhaAtual = request.form.get("senhaAtual")
    senhaNova = request.form.get("senhaNova")

    funcionario = buscarFuncionario(codigo)
    if funcionario is None:
        msg = "Funcionário não encontrado"
        return render_template("senha.html", mensagem=msg)

    if funcionario["senha"] != senhaAtual:
        msg = "Senha atual incorreta."
        return render_template("senha.html", mensagem=msg)
    
    funcionario["senha"] = senhaNova
    msg = "Senha alterada com sucesso."
    return render_template("senha.html", mensagem=msg)


@app.route("/cadastrar", methods=['POST'])
def cadastrarFuncionario():

    codigo = request.form.get("codigo")
    nome = request.form.get("nome")
    salario = float(request.form.get("salario"))
    idade = int(request.form.get("idade"))
    departamento = request.form.get("departamento")
    senha = request.form.get("senha")

    funcionario = {
        "codigo": codigo,
        "nome": nome,
        "salario": salario,
        "idade": idade,
        "departamento": departamento,
        "senha": senha
    }

    funcionarios.append(funcionario)
    mensagem = f"Usuário {funcionario['nome']} adicionado com sucesso."

    return render_template("cadastro.html", mensagem=mensagem)


def buscarFuncionario(codigo):

    for f in funcionarios:
        if f["codigo"] == codigo:
            return f
    
    return None


