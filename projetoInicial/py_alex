from flask import Flask, render_template, request, session, redirect, url_for
from functools import wraps

app = Flask(__name__)

app.secret_key = "chave_secreta"

funcionarios = []

def verificar(func):
    @wraps(func)
    def verificarLogado(*args, **kwargs):
        if "usuario" not in session:
            return redirect(url_for("home"))
        
        return func(*args, **kwargs)
    
    return verificarLogado

@app.route('/')
def home():
    
    funcionario = {
        "codigo": "001",
        "nome": "Kayque",
        "salario": 1000,
        "idade": 19,
        "departamento": "admin",
        "senha": "123"
    }

    if not funcionarios:
        funcionarios.append(funcionario)
    return render_template("principal.html")

@app.route("/autenticar", methods=['POST'])
def autenticarUsuario():

    codigo = request.form.get("codigoUsuario")
    senha = request.form.get("senhaUsuario")

    funcionario = buscarFuncionario(codigo)
    if funcionario is None:
        msg = "Funcionário não encontrado"
        return render_template("principal.html", mensagem=msg)
    
    if funcionario["senha"] == senha:
        session["usuario"] = funcionario["nome"]
        session["departamento"] = funcionario["departamento"]
        return redirect(url_for("rotaLogado"))
    else:
        msg = "login ou senha incorretos, tente novamente"
        return render_template("principal.html", mensagem=msg)

